views:
  - type: map
    name: Map View
    filters:
      and:
        - categories.containsAny(link("Places"))
    coordinates: note.coordinates
    markerIcon: note.icon
    markerColor: note.color
    mapTiles:
      - https://tiles.openfreemap.org/styles/bright
    mapTilesDark: []
  - type: table
    name: Table
    filters:
      and:
        - categories.containsAny(link("Places"))
